{
  "name": "@chanceux/vue-virtual-list",
  "type": "module",
  "version": "0.0.4",
  "private": false,
  "description": "A simple virtual list component for Vue 3",
  "author": "Chanceux-L",
  "license": "ISC",
  "homepage": "https://github.com/Chanceux-L/vue-virtual-list",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chanceux-L/vue-virtual-list"
  },
  "keywords": [
    "vue",
    "vue3",
    "typescript",
    "virtual-list",
    "virtual-scroll"
  ],
  "exports": {
    ".": {
      "import": "./dist/virtual-list.es.js",
      "require": "./dist/virtual-list.umd.js"
    }
  },
  "main": "./dist/virtual-list.umd.js",
  "module": "./dist/virtual-list.es.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "vue-tsc -b && vite build && vite build --config demo/vite.config.ts && cp -r demo/demo-dist/* dist/",
    "preview": "vite preview",
    "release": "npm publish --access public --no-git-checks",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "lodash-es": "^4.17.21",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.12.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.14.1",
    "@vitejs/plugin-vue": "^5.2.2",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.25.1",
    "typescript": "~5.7.2",
    "vite": "^6.3.4",
    "vite-plugin-dts": "^4.5.3",
    "vue-tsc": "^2.2.8"
  }
}
